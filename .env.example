# ─── RPC ──────────────────────────────────────────────────────────────────────
# Use Helius for best reliability. Get one free at https://helius.dev
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# ─── WALLETS ──────────────────────────────────────────────────────────────────
# Comma-separated base58 private keys. If omitted, wallets.json is used.
# Each enabled wallet needs SOL to cover trades + fees.
PRIVATE_KEYS=KEY1_BASE58,KEY2_BASE58,KEY3_BASE58

# ─── TOKEN ────────────────────────────────────────────────────────────────────
# Default $SUEDE Solana token mint. Change this if you are running the Suede-branded
# dashboard against a different token.
TOKEN_MINT=2nCeHpECQvnMfzjU5fDMAKws1vBxMzxvWr6qqLpApump

# ─── TRADE SETTINGS ───────────────────────────────────────────────────────────
# SOL per trade (randomised between MIN and MAX)
TRADE_AMOUNT_SOL_MIN=0.01
TRADE_AMOUNT_SOL_MAX=0.05

# Delay between trades in seconds (randomised between MIN and MAX)
DELAY_MIN_SEC=15
DELAY_MAX_SEC=45

# Slippage tolerance in basis points (100 = 1%, 500 = 5%)
SLIPPAGE_BPS=300

# How many full buy→sell cycles to run (0 = run forever)
CYCLES=0

# Priority fee in microlamports (helps land txns faster; 5000 = ~0.000005 SOL)
PRIORITY_FEE_MICROLAMPORTS=5000

# Retry Jupiter/API calls when a rate limit or transient server error happens.
API_RETRY_ATTEMPTS=5
API_RETRY_BASE_DELAY_MS=1500

# Public Jupiter quote endpoints rate-limit bursts. Keep calls paced, and pause
# longer after a 429 instead of retrying immediately.
API_MIN_INTERVAL_MS=1500
API_RATE_LIMIT_COOLDOWN_MS=30000

# ─── MARKET MAKER SETTINGS ───────────────────────────────────────────────────
# Default false preserves live execution. Set true to quote/log without signing.
DRY_RUN=false

# rebalance = only trade outside inventory band
# pulse     = always do small alternating trades
# hybrid    = rebalance outside band, pulse inside band
MODE=hybrid

# false in pulse mode avoids pre-trade market valuation quotes. The bot then
# uses wallet balances and only calls Jupiter for actual swap quotes.
USE_VALUATION_QUOTES=false

# $SUEDE uses 6 decimals. Change this if your configured token uses another value.
TOKEN_DECIMALS=6

# Target inventory as token value / total wallet value.
# Example: 50 means aim for 50% SOL value and 50% SUEDE value.
TARGET_TOKEN_VALUE_PCT=50

# No-trade band around the target. With target 50 and band 12:
# buy below 38%, sell above 62%, hold between 38% and 62%.
INVENTORY_BAND_PCT=12

# Skip any quote whose reported price impact is above this value.
MAX_PRICE_IMPACT_PCT=3

# Keep this much SOL in each wallet for fees/rent.
MIN_SOL_RESERVE=0.005

# When enabled, the selected rotating wallet is topped up from the funding
# wallet right before it trades. The funding wallet still needs SOL.
AUTO_TOP_UP_ENABLED=false
AUTO_TOP_UP_MIN_SOL=0.012
AUTO_TOP_UP_TARGET_SOL=0.215
AUTO_SWEEP_BACK_ENABLED=true
AUTO_SWEEP_ON_START=false
AUTO_SWEEP_RESERVE_SOL=0.005
STARTUP_SCAN_ENABLED=false

# ─── FUNDING / SWEEP ──────────────────────────────────────────────────────────
# Send SOL to the generated funding wallet, then distribute evenly to wallets.
# If unset, the dashboard/CLI creates local funding-wallet.json.
# FUNDING_WALLET_PRIVATE_KEY=BASE58_PRIVATE_KEY

# Keep this much SOL in the funding wallet after even distribution.
FUNDING_SOURCE_RESERVE_SOL=0.01

# Keep this much SOL in each managed wallet when sweeping back after the run.
SWEEP_WALLET_RESERVE_SOL=0.005

# Pulse trades use this percent of the normal random trade size.
PULSE_TRADE_PCT=25

# Address rotation selects one eligible enabled wallet per decision.
# Wait this long before the same wallet address can be selected again.
WALLET_COOLDOWN_SEC=90

# 0 = use every enabled wallet in wallets.json. Set a number to cap active addresses.
ACTIVE_MAKER_COUNT=0

# Stop after this many failed quote/swap attempts in a row.
MAX_CONSECUTIVE_FAILURES=5

# Optional completed-cycle limit per wallet address. 0 = no per-address limit.
MAX_CYCLES_PER_WALLET=0

# JSONL audit log for every decision/trade.
LEDGER_PATH=trades.jsonl

# ─── TELEGRAM CONTROL BOT ────────────────────────────────────────────────────
# Create a bot with @BotFather, paste the token here, then allow only your chat.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Comma-separated Telegram chat ids allowed to use money-moving commands.
# Start the bot once and message it; unauthorized attempts are logged with chat id.
TELEGRAM_ALLOWED_CHAT_IDS=YOUR_TELEGRAM_CHAT_ID

# Ignore old queued Telegram messages when the control bot starts.
TELEGRAM_SKIP_PENDING_UPDATES=true
